# ASR backend: local (faster-whisper) or cloudflare
ASR_BACKEND=local

# Local Whisper — model loaded ONCE at startup (singleton)
LOCAL_WHISPER_MODEL=base
# base | small | medium | large-v3
LOCAL_WHISPER_DEVICE=cpu
# cpu | cuda
LOCAL_WHISPER_COMPUTE_TYPE=int8
# int8 | float16 (float16 needs cuda for best speed)
# Partial (faster) vs final (stable) decode
LOCAL_WHISPER_BEAM_SIZE_PARTIAL=1
LOCAL_WHISPER_BEAM_SIZE_FINAL=5
LOCAL_WHISPER_WORD_TIMESTAMPS=true

# Cloudflare Workers AI: ASR (when ASR_BACKEND=cloudflare) and refine-transcript (LLM)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Optional backend recording (one file per WebSocket session). Disabled by default.
ENABLE_AUDIO_RECORDING=false
ENABLE_BACKEND_RECORDING=false
BACKEND_RECORD_FORMAT=wav
# wav | mp3 (wav preferred: no re-encode, safe lifecycle)
BACKEND_RECORD_DIR=./recordings
BACKEND_RECORD_GAIN=2.0
# 1.5–4.0 gain applied only to recorded file; STT stream unchanged
BACKEND_RECORD_BITRATE=128k
# for MP3 only

# Session transcript storage: one .txt per WebSocket (final segments only, append-only)
TRANSCRIPT_SAVE_ENABLED=true
TRANSCRIPT_DIR=./transcripts
TRANSCRIPT_ADD_TIMESTAMPS=false

# Real-time STT: rolling buffer (default) vs silence-based chunker
STT_USE_ROLLING_BUFFER=true
STT_WINDOW_SECONDS=5.0
STT_STEP_SECONDS=1.0
STT_MIN_CHUNK_SECONDS=0.5
STT_COMMIT_AGE_SECONDS=2.0

# Optional overrides (legacy chunking when STT_USE_ROLLING_BUFFER=false)
CHUNK_DURATION_MS=1500
OVERLAP_MS=300
SILENCE_COMMIT_MS=600

# Context-aware re-transcription: LLM prioritas OpenRouter → Cloudflare → Hugging Face
# Setidaknya satu provider harus dikonfigurasi (API key / account+token)
REFINE_CHAT_ENABLED=true
# Prioritas provider (comma-separated): openrouter, cloudflare, huggingface
LLM_PROVIDER_PRIORITY=openrouter,cloudflare,huggingface
# OpenRouter (prioritas 1): https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Cloudflare Workers AI (prioritas 2) — pakai CLOUDFLARE_ACCOUNT_ID / CLOUDFLARE_API_TOKEN di atas
REFINE_CF_MODEL=
# Hugging Face Inference (prioritas 3): https://huggingface.co/inference-api
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=
REFINE_CHAT_MAX_TOKENS=2048
REFINE_AUDIO_REFERENCE_SECONDS=30.0

# Chat context: false = ringkasan+snippet ke LLM; true = transcript mentah ke LLM (sampai CHAT_ONLY_RELEVANT_SNIPPET_MAX_CHARS; bisa 413).
CHAT_USE_ONLY_RELEVANT_SNIPPET=true
# Transkrip sebagai beberapa pesan system berurutan (chunk baris). Jika true: bentuk payload chat = instruksi + segmen transkrip (mengabaikan CHAT_LLM_COMPACT_KNOWLEDGE untuk isi transkrip); ringkasan LLM tidak dipanggil di /api/chat.
CHAT_KNOWLEDGE_MULTI_SYSTEM=true
CHAT_KNOWLEDGE_CHUNK_LINES=50
CHAT_KNOWLEDGE_MAX_CHUNKS=40
CHAT_KNOWLEDGE_MAX_CHARS_PER_CHUNK=12000

# true = prompt LLM tanpa teks transkrip (tidak ringkasan, tidak cuplikan terpotong); + CHAT_LLM_EXTRA_SYSTEM_PROMPT. Transcript tetap di session.
CHAT_LLM_COMPACT_KNOWLEDGE=true
# Hanya dipakai jika CHAT_LLM_COMPACT_KNOWLEDGE=false: both | summary_only | excerpt_only.
CHAT_LLM_COMPACT_CONTEXT_PARTS=both
# Instruksi tambahan di system prompt; wajib berguna bila COMPACT_KNOWLEDGE=true (satu-satunya aturan kustom ke LLM).
CHAT_LLM_EXTRA_SYSTEM_PROMPT=
# Hanya jika COMPACT_KNOWLEDGE=false: cuplikan fallback saat ringkasan tidak valid.
CHAT_LLM_KNOWLEDGE_FALLBACK_SNIPPET_CHARS=12000
CHAT_ONLY_RELEVANT_SNIPPET_MAX_CHARS=50000
# Max karakter untuk global summary (parsed dari LLM); besar = konteks full tidak terpotong
CHAT_GLOBAL_SUMMARY_MAX_CHARS=4000
# /api/session/activate: batas batch LLM + chunk besar agar aktivasi tidak lama (transcript panjang)
CHAT_ACTIVATE_MAX_COMPRESSION_BATCHES=6
CHAT_ACTIVATE_CHUNK_CHARS=10000

# PICOVOICE_API_KEY=your_pico_voice_api_key

# Persona (English): assistant/identity.md (name aliases), soul.md, constraints.md
# ASSISTANT_PERSONA_DIR=assistant