# ASR backend: local (faster-whisper) or cloudflare
ASR_BACKEND=local

# Local Whisper — model loaded ONCE at startup (singleton)
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_BEAM_SIZE_PARTIAL=1
LOCAL_WHISPER_BEAM_SIZE_FINAL=5
LOCAL_WHISPER_WORD_TIMESTAMPS=true

# Cloudflare Workers AI: ASR (when ASR_BACKEND=cloudflare) and refine-transcript (LLM)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Optional backend recording (one file per WebSocket session). Disabled by default.
ENABLE_AUDIO_RECORDING=false
ENABLE_BACKEND_RECORDING=false
BACKEND_RECORD_FORMAT=wav
BACKEND_RECORD_DIR=./recordings
BACKEND_RECORD_GAIN=2.0
BACKEND_RECORD_BITRATE=128k

# --- Session transcript storage ---
TRANSCRIPT_SAVE_ENABLED=true
# file = ./transcripts/*.txt (default) | postgresql = PostgreSQL
USE_DATABASE=false
TRANSCRIPT_STORAGE=file
TRANSCRIPT_DIR=./transcripts
TRANSCRIPT_ADD_TIMESTAMPS=false

# PostgreSQL (required when USE_DATABASE=true or TRANSCRIPT_STORAGE=postgresql)
# Local Docker: postgresql+asyncpg://postgres:postgres@postgres:5432/voice_back
# Render/Supabase hosted: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/voice_back

# --- Cloud object storage (session audio) ---
# When USE_DATABASE=true + ENABLE_BACKEND_RECORDING=true, audio is uploaded here;
# PostgreSQL stores only recording_url (not the binary).
OBJECT_STORAGE_BACKEND=none
# supabase | firebase | none

# Supabase Storage (https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=recordings
SUPABASE_STORAGE_PREFIX=sessions

# Firebase Storage (https://firebase.google.com)
FIREBASE_CREDENTIALS_PATH=
# Path to service account JSON file (local dev)
FIREBASE_CREDENTIALS_JSON=
# Inline JSON string (Render, Hugging Face Spaces — paste full service account JSON)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_STORAGE_PREFIX=sessions
FIREBASE_STORAGE_MAKE_PUBLIC=true

# Real-time STT: rolling buffer (default) vs silence-based chunker
STT_USE_ROLLING_BUFFER=true
STT_WINDOW_SECONDS=5.0
STT_STEP_SECONDS=1.0
STT_MIN_CHUNK_SECONDS=0.5
STT_COMMIT_AGE_SECONDS=2.0

CHUNK_DURATION_MS=1500
OVERLAP_MS=300
SILENCE_COMMIT_MS=600

# Context-aware re-transcription: LLM prioritas OpenRouter → Cloudflare → Hugging Face
REFINE_CHAT_ENABLED=true
LLM_PROVIDER_PRIORITY=openrouter,cloudflare,huggingface
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
REFINE_CF_MODEL=
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=
REFINE_CHAT_MAX_TOKENS=2048
REFINE_AUDIO_REFERENCE_SECONDS=30.0

CHAT_USE_ONLY_RELEVANT_SNIPPET=true
CHAT_KNOWLEDGE_MULTI_SYSTEM=true
CHAT_KNOWLEDGE_CHUNK_LINES=50
CHAT_KNOWLEDGE_MAX_CHUNKS=40
CHAT_KNOWLEDGE_MAX_CHARS_PER_CHUNK=12000
CHAT_LLM_COMPACT_KNOWLEDGE=true
CHAT_LLM_COMPACT_CONTEXT_PARTS=both
CHAT_LLM_EXTRA_SYSTEM_PROMPT=
CHAT_LLM_KNOWLEDGE_FALLBACK_SNIPPET_CHARS=12000
CHAT_ONLY_RELEVANT_SNIPPET_MAX_CHARS=50000
CHAT_GLOBAL_SUMMARY_MAX_CHARS=4000
CHAT_ACTIVATE_MAX_COMPRESSION_BATCHES=6
CHAT_ACTIVATE_CHUNK_CHARS=10000

# Persona: assistant/identity.md, soul.md, constraints.md
# ASSISTANT_PERSONA_DIR=assistant
